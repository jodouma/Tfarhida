rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roomPath(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function playerPath(roomId, uid) {
      return /databases/$(database)/documents/rooms/$(roomId)/players/$(uid);
    }

    function isMember(roomId) {
      return signedIn() && exists(playerPath(roomId, request.auth.uid));
    }

    function isHost(roomId) {
      return signedIn() && exists(roomPath(roomId)) && get(roomPath(roomId)).data.hostUid == request.auth.uid;
    }

    function onlyPlayerPresenceFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "displayName",
        "avatar",
        "color",
        "online",
        "lastSeenAt"
      ]);
    }

    match /rooms/{roomId} {
      allow create: if signedIn() && request.resource.data.hostUid == request.auth.uid;

      // Authenticated users may read a room by code before joining.
      // This keeps invite links usable in the client-only GitHub Pages MVP.
      allow read: if signedIn();

      allow update: if isHost(roomId)
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.code == resource.data.code;

      allow delete: if false;

      match /players/{uid} {
        allow read: if isMember(roomId) || isHost(roomId);
        allow create: if signedIn() && request.auth.uid == uid;
        allow update: if signedIn() && (
          (request.auth.uid == uid && onlyPlayerPresenceFieldsChanged()) ||
          isHost(roomId)
        );
        allow delete: if false;
      }

      match /rounds/{roundId} {
        allow read: if isMember(roomId) || isHost(roomId);
        allow create, update: if isHost(roomId);
        allow delete: if false;

        match /submissions/{uid} {
          allow read: if isMember(roomId) || isHost(roomId);
          allow create: if signedIn() && request.auth.uid == uid && isMember(roomId);
          allow update: if false;
          allow delete: if false;
        }
      }

      match /private/{uid} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create, update: if isHost(roomId);
        allow delete: if false;
      }

      match /events/{eventId} {
        allow read: if isMember(roomId) || isHost(roomId);
        allow create: if isMember(roomId) || isHost(roomId);
        allow update, delete: if false;
      }
    }
  }
}
